rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ Firestore compte chaque get()/exists() dans un quota de ~10 par
    // évaluation de règle (single doc) / ~20 (batch), MÊME si le chemin a
    // déjà été lu ailleurs dans la même règle. Règle d'or dans ce fichier :
    // chaque `allow` ne doit invoquer qu'UNE seule fonction qui fait des
    // get() (ex: hasAnyAdminAccess()), jamais plusieurs empilées avec ||.
    // Comme la page "Accès pages" force toujours 'admin' dans chaque
    // permission (impossible à décocher côté UI), hasPagePermission(page)
    // est déjà vrai pour un vrai admin : inutile d'ajouter isAdmin() en plus.

    function isAuth() {
      return request.auth != null;
    }

    function userRoles() {
      let acc = get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data;
      let dIds = acc.get('dancerIds', []);
      return acc.get('roles', [])
        .concat(dIds.size() > 0 ? get(/databases/$(database)/documents/dancers/$(dIds[0])).data.get('roles', []) : [])
        .concat(dIds.size() > 1 ? get(/databases/$(database)/documents/dancers/$(dIds[1])).data.get('roles', []) : [])
        .concat(dIds.size() > 2 ? get(/databases/$(database)/documents/dancers/$(dIds[2])).data.get('roles', []) : []);
    }

    function pagePerms() {
      return get(/databases/$(database)/documents/appSettings/main).data.get('pagePermissions', {});
    }

    function isAdmin() {
      return isAuth() && userRoles().hasAny(['admin']);
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isInstructor() {
      return isAuth() && userRoles().hasAny(['instructor', 'admin']);
    }

    function hasPagePermission(page) {
      let roles = userRoles();
      let perms = pagePerms();
      return isAuth() && roles.hasAny(perms.get(page, ['admin']));
    }

    function cannotChangeProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isActive']);
    }

    // Vrai dès qu'un rôle a accès à AU MOINS UNE page admin (peu importe
    // laquelle) via 'Accès pages'. Sert à autoriser la LECTURE des
    // collections transversales (comptes, cotisations, échéances...) que
    // beaucoup de pages doivent croiser pour afficher des noms/emails/
    // montants, sans avoir à cartographier chaque page → chaque collection.
    // L'ÉCRITURE reste toujours gérée page par page via des fonctions dédiées.
    function hasAnyAdminAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/club-settings', ['admin'])) ||
        roles.hasAny(perms.get('/admin/seasons', ['admin'])) ||
        roles.hasAny(perms.get('/admin/dance-styles', ['admin'])) ||
        roles.hasAny(perms.get('/admin/levels', ['admin'])) ||
        roles.hasAny(perms.get('/admin/rooms', ['admin'])) ||
        roles.hasAny(perms.get('/admin/courses', ['admin'])) ||
        roles.hasAny(perms.get('/admin/interruptions', ['admin'])) ||
        roles.hasAny(perms.get('/admin/public-holidays', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/planning', ['admin'])) ||
        roles.hasAny(perms.get('/admin/dancers', ['admin'])) ||
        roles.hasAny(perms.get('/admin/trial', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/trial', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/roles', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/profile-fields', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/custom-fields', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/profile-mapping', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/welcome-qr', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payment-plans', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/new', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/today', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/bank-deposits', ['admin'])) ||
        roles.hasAny(perms.get('/admin/pricing-plans', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/bank-accounts', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/cheques', ['admin'])) ||
        roles.hasAny(perms.get('/admin/media', ['admin'])) ||
        roles.hasAny(perms.get('/admin/documents-library', ['admin'])) ||
        roles.hasAny(perms.get('/admin/announcements', ['admin'])) ||
        roles.hasAny(perms.get('/admin/chat-channels', ['admin'])) ||
        roles.hasAny(perms.get('/admin/notification-channels', ['admin'])) ||
        roles.hasAny(perms.get('/admin/notifications/send', ['admin'])) ||
        roles.hasAny(perms.get('/admin/private-messages', ['admin'])) ||
        roles.hasAny(perms.get('/admin/emails', ['admin']));
    }

    // Écriture memberships/paymentGroups : réservé aux pages qui approuvent
    // ou saisissent réellement un paiement, + Danseurs pour l'annulation
    // d'adhésion en cours de saison.
    function hasMembershipWriteAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/payment-plans', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/new', ['admin'])) ||
        roles.hasAny(perms.get('/admin/dancers', ['admin']));
    }

    // Écriture dancers, hors champs protégés (roles/isActive) : pages qui
    // modifient une fiche danseur sans changer son rôle/statut.
    function hasDancerWriteAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) || roles.hasAny(perms.get('/admin/dancers', ['admin']));
    }

    // Écriture dancers SANS restriction de champs (roles inclus) : pages
    // dont la fonction même est de faire évoluer le rôle d'un danseur
    // (gestion des rôles, conversion essai → membre).
    function hasDancerRoleChangeAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/dancers', ['admin'])) ||
        roles.hasAny(perms.get('/admin/trial', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payment-plans', ['admin']));
    }

    // Écriture paymentInstallments : pages qui pointent/mettent à jour des
    // échéances (encaissement, saisie, bordereaux, chèques), + Danseurs
    // pour annuler les échéances restantes lors d'une annulation d'adhésion.
    function hasInstallmentWriteAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/payments/today', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/cheques', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/new', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/bank-deposits', ['admin'])) ||
        roles.hasAny(perms.get('/admin/dancers', ['admin']));
    }

    // Collections croisées par plusieurs pages "paiement" (chequeImages,
    // bankAccounts en lecture, doc payments...).
    function hasPaymentPageAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/payments/cheques', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/new', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/bank-deposits', ['admin'])) ||
        roles.hasAny(perms.get('/admin/payments/today', ['admin']));
    }

    // appSettings : plusieurs pages de settings partagent ce document.
    function hasSettingsPageAccess() {
      let roles = userRoles();
      let perms = pagePerms();
      return roles.hasAny(['admin']) ||
        roles.hasAny(perms.get('/admin/settings/trial', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/profile-fields', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/profile-mapping', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/welcome-qr', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/session-detail', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/calendar-sync', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/payment-info', ['admin'])) ||
        roles.hasAny(perms.get('/admin/settings/google-integration', ['admin']));
    }

    // ── clubProfile ────────────────────────────────────────────────────────────
    match /clubProfile/{docId} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/club-settings');
    }

    // ── accounts ──────────────────────────────────────────────────────────────
    match /accounts/{uid} {
      allow read: if isOwner(uid) || hasAnyAdminAccess();
      // Le titulaire crée son propre doc ; roles doit être vide (pas d'auto-attribution)
      allow create: if isOwner(uid) &&
        request.resource.data.roles.size() == 0;
      // Le titulaire peut modifier son doc mais pas roles ni isActive ;
      // la page inscriptions/registrations met aussi à jour ce doc (annulation),
      // et la page Danseurs synchronise les roles du compte avec ceux du danseur.
      allow update: if (isOwner(uid) && cannotChangeProtectedFields()) || hasPagePermission('/admin/courses') || hasDancerRoleChangeAccess();
      allow delete: if isAdmin();
    }

    // ── dancers ───────────────────────────────────────────────────────────────
    match /dancers/{dancerId} {
      allow read: if isAuth();
      // Le titulaire crée un danseur pour son compte ; roles limités à member/trial
      // L'admin/bureau (accès page Danseurs) peut créer un danseur pour N'IMPORTE
      // QUEL compte existant, avec n'importe quel rôle (ex: ajout à une famille).
      allow create: if (
        isAuth() &&
        request.resource.data.accountId == request.auth.uid &&
        request.resource.data.roles.hasOnly(['member', 'trial'])
      ) || hasDancerWriteAccess();
      // Le titulaire peut modifier ses danseurs mais pas roles ni isActive
      allow update: if (
        isAuth() &&
        resource.data.accountId == request.auth.uid &&
        cannotChangeProtectedFields()
      ) || (
        hasDancerWriteAccess() && cannotChangeProtectedFields()
      ) || hasDancerRoleChangeAccess();
      allow delete: if (
        isAuth() && resource.data.accountId == request.auth.uid
      ) || isAdmin();
    }

    // ── seasons ────────────────────────────────────────────────────────────────
    match /seasons/{id} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/seasons');
    }

    // ── appSettings ────────────────────────────────────────────────────────────
    // Un seul document regroupe plusieurs réglages (essai, champs profil,
    // mapping, QR accueil, pagePermissions...). Le champ pagePermissions
    // reste modifiable par un vrai admin uniquement, pour éviter qu'un rôle
    // avec accès à une page de settings ne puisse s'auto-accorder des droits.
    match /appSettings/{id} {
      allow read: if true;
      allow write: if hasSettingsPageAccess() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pagePermissions']);
      allow write: if isAdmin();
    }

    // ── config (SMTP, etc.) ────────────────────────────────────────────────────
    match /config/{id} {
      allow read, write: if isAdmin();
    }

    // ── catalogue ─────────────────────────────────────────────────────────────
    match /danceStyles/{id} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/dance-styles');
    }

    match /levels/{id} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/levels');
    }

    match /rooms/{id} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/rooms');
    }

    match /courses/{id} {
      allow read: if true;
      allow create, delete: if hasPagePermission('/admin/courses');
      allow update: if hasPagePermission('/admin/courses') || (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeRegistrationCount'])
      );
    }

    match /sessions/{id} {
      allow read: if true;
      allow create, delete: if hasPagePermission('/admin/courses');
      // La note de programme (fiche détail d'une séance) est éditable par les
      // rôles configurés dans appSettings.sessionNoteEditRoles, sans passer
      // par la permission /admin/courses — mais uniquement ce champ-là.
      allow update: if hasPagePermission('/admin/courses') || (
        isAuth() &&
        userRoles().hasAny(get(/databases/$(database)/documents/appSettings/main).data.get('sessionNoteEditRoles', [])) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['programNote'])
      );
    }

    match /calendarTokens/{token} {
      // Écrit/lu uniquement par les Cloud Functions (Admin SDK) — le client
      // n'a jamais besoin d'un accès direct à cette collection.
      allow read, write: if false;
    }

    match /googleTokens/{id} {
      // Tokens OAuth Google (contacts + envoi d'emails) — uniquement Admin SDK.
      allow read, write: if false;
    }

    match /emailCampaigns/{id} {
      // Créé/mis à jour uniquement par les Cloud Functions (sendClubEmail,
      // trackEmailOpen) — lecture pour l'historique sur la page d'envoi.
      allow read: if hasPagePermission('/admin/emails');
      allow write: if false;

      match /opens/{ipHash} {
        // Déduplication des ouvertures par IP — jamais lu/écrit par le client.
        allow read, write: if false;
      }
    }

    match /interruptions/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/interruptions');
    }

    match /publicHolidays/{id} {
      allow read: if true;
      allow write: if hasPagePermission('/admin/public-holidays');
    }

    match /notifications/{id} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function uniquement
    }

    match /registrations/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || hasPagePermission('/admin/courses') || hasPagePermission('/admin/dancers');
      allow delete: if hasPagePermission('/admin/courses');
    }

    // ── paiements ─────────────────────────────────────────────────────────────
    match /pricingPlans/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/pricing-plans');
    }

    match /memberships/{id} {
      allow read: if isOwner(resource.data.userId) || hasAnyAdminAccess();
      allow create: if (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update: if hasMembershipWriteAccess() || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentMethod', 'installmentIds', 'updatedAt']) &&
        resource.data.paymentPlanStatus == 'pending'
      );
      allow delete: if hasPagePermission('/admin/payment-plans') || (
        isOwner(resource.data.userId) &&
        resource.data.paymentPlanStatus == 'pending' &&
        resource.data.installmentIds.size() == 0
      );
    }

    match /paymentGroups/{id} {
      allow read: if isOwner(resource.data.userId) || hasAnyAdminAccess();
      allow create: if (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update: if hasMembershipWriteAccess() || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['installmentIds', 'updatedAt']) &&
        resource.data.paymentPlanStatus == 'pending'
      );
      allow delete: if hasPagePermission('/admin/payment-plans') || (
        isOwner(resource.data.userId) &&
        resource.data.paymentPlanStatus == 'pending' &&
        resource.data.installmentIds.size() == 0
      );
    }

    match /payments/{id} {
      allow read, write: if hasPaymentPageAccess();
    }

    match /paymentInstallments/{id} {
      allow read: if isOwner(resource.data.userId) || hasAnyAdminAccess();
      allow create: if (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update, delete: if hasInstallmentWriteAccess();
    }

    match /chequeImages/{id} {
      allow read, write: if hasPaymentPageAccess();
    }

    match /bankDeposits/{id} {
      allow read: if hasPagePermission('/admin/payments/bank-deposits') || hasPagePermission('/admin/finances/dashboard') || hasPagePermission('/admin/exports');
      allow write: if hasPagePermission('/admin/payments/bank-deposits');
    }

    match /bankAccounts/{id} {
      // Un RIB est fait pour être communiqué : tout utilisateur connecté peut
      // le lire (nécessaire pour afficher les coordonnées lors d'un paiement
      // par virement dans le parcours de cotisation).
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/settings/bank-accounts');
    }

    match /attendances/{id} {
      allow read: if isInstructor() || hasPagePermission('/admin/exports');
      allow create: if false; // Cloud Function uniquement
      allow update, delete: if isAdmin();
    }

    match /kioskSessions/{id} {
      allow read: if isAuth();
      allow create, update: if isInstructor();
      allow delete: if isAdmin();
    }

    // ── media ─────────────────────────────────────────────────────────────────
    match /media/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/media');
    }

    // ── announcements (actualités home) ──────────────────────────────────────
    match /announcements/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/announcements');
    }

    // ── notificationChannels ──────────────────────────────────────────────────
    match /notificationChannels/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/notification-channels');
    }

    // ── chat ──────────────────────────────────────────────────────────────────
    match /chatChannels/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/chat-channels');
    }

    match /chatMessages/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if hasPagePermission('/admin/chat-channels');
    }

    match /privateMessages/{id} {
      allow read: if (isAuth() && resource.data.fromAccountId == request.auth.uid) || hasPagePermission('/admin/private-messages');
      allow create: if isAuth() && request.auth.uid == request.resource.data.fromAccountId;
      allow update, delete: if hasPagePermission('/admin/private-messages');
    }

    // ── documents personnels (reçus, attestations) ────────────────────────────
    match /documents/{id} {
      allow read: if isOwner(resource.data.userId) || hasPagePermission('/admin/dancers');
      allow create, update, delete: if false; // Cloud Function uniquement
    }

    // ── bibliothèque de documents du club ─────────────────────────────────────
    match /documentLibrary/{id} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/documents-library') || (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloadCount'])
      );
    }

    match /documentLibrary/{docId}/versions/{versionId} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/documents-library');
    }

    // ── roles (configuration des rôles) ──────────────────────────────────────
    // Volontairement restreint au vrai rôle admin uniquement (jamais dynamique
    // via pagePermissions) pour éviter qu'un rôle puisse s'auto-accorder des droits.
    match /roles/{roleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── profileSchemas (champs personnalisés) ─────────────────────────────────
    match /profileSchemas/{schemaId} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/settings/custom-fields');
    }

    match /profileSchemas/{schemaId}/fields/{fieldId} {
      allow read: if isAuth();
      allow write: if hasPagePermission('/admin/settings/custom-fields');
    }
  }
}
