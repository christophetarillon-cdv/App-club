rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Rôles combinés (compte + jusqu'à 3 danseurs liés)
    function userRoles() {
      let acc = get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data;
      let dIds = acc.get('dancerIds', []);
      return acc.get('roles', [])
        .concat(dIds.size() > 0 ? get(/databases/$(database)/documents/dancers/$(dIds[0])).data.get('roles', []) : [])
        .concat(dIds.size() > 1 ? get(/databases/$(database)/documents/dancers/$(dIds[1])).data.get('roles', []) : [])
        .concat(dIds.size() > 2 ? get(/databases/$(database)/documents/dancers/$(dIds[2])).data.get('roles', []) : []);
    }

    function isAdmin() {
      return isAuth() && userRoles().hasAny(['admin']);
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isInstructor() {
      return isAuth() && (isAdmin() || userRoles().hasAny(['instructor']));
    }

    // Accès dynamique basé sur appSettings/main.pagePermissions, configuré
    // depuis la page "Accès pages". Si aucune permission n'est définie
    // pour la page, seul admin est autorisé par défaut.
    function hasPagePermission(page) {
      let perms = get(/databases/$(database)/documents/appSettings/main).data.get('pagePermissions', {});
      let allowed = perms.get(page, ['admin']);
      return isAuth() && userRoles().hasAny(allowed);
    }

    function cannotChangeProtectedFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'isActive']);
    }

    // ── clubProfile ────────────────────────────────────────────────────────────
    match /clubProfile/{docId} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/club-settings');
    }

    // ── accounts ──────────────────────────────────────────────────────────────
    match /accounts/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // Le titulaire crée son propre doc ; roles doit être vide (pas d'auto-attribution)
      allow create: if isOwner(uid) &&
        request.resource.data.roles.size() == 0;
      // Le titulaire peut modifier son doc mais pas roles ni isActive
      allow update: if (isOwner(uid) && cannotChangeProtectedFields()) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── dancers ───────────────────────────────────────────────────────────────
    match /dancers/{dancerId} {
      allow read: if isAuth();
      // Le titulaire crée un danseur pour son compte ; roles limités à member/trial
      allow create: if isAuth() &&
        request.resource.data.accountId == request.auth.uid &&
        request.resource.data.roles.hasOnly(['member', 'trial']);
      // Le titulaire peut modifier ses danseurs mais pas roles ni isActive
      allow update: if (
        isAuth() &&
        resource.data.accountId == request.auth.uid &&
        cannotChangeProtectedFields()
      ) || isAdmin() || (
        hasPagePermission('/admin/dancers') && cannotChangeProtectedFields()
      ) || hasPagePermission('/admin/trial');
      allow delete: if (
        isAuth() && resource.data.accountId == request.auth.uid
      ) || isAdmin();
    }

    // ── seasons ────────────────────────────────────────────────────────────────
    match /seasons/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/seasons');
    }

    // ── appSettings ────────────────────────────────────────────────────────────
    // Un seul document regroupe plusieurs réglages (essai, champs profil,
    // mapping, QR accueil, pagePermissions...). Le champ pagePermissions
    // reste modifiable par un vrai admin uniquement, pour éviter qu'un rôle
    // avec accès à une page de settings ne puisse s'auto-accorder des droits.
    match /appSettings/{id} {
      allow read: if true;
      allow write: if isAdmin() || (
        (
          hasPagePermission('/admin/settings/trial') ||
          hasPagePermission('/admin/settings/profile-fields') ||
          hasPagePermission('/admin/settings/profile-mapping') ||
          hasPagePermission('/admin/settings/welcome-qr')
        ) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pagePermissions'])
      );
    }

    // ── config (SMTP, etc.) ────────────────────────────────────────────────────
    match /config/{id} {
      allow read, write: if isAdmin();
    }

    // ── catalogue ─────────────────────────────────────────────────────────────
    match /danceStyles/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/dance-styles');
    }

    match /levels/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/levels');
    }

    match /rooms/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/rooms');
    }

    match /courses/{id} {
      allow read: if true;
      allow create, delete: if isAdmin() || hasPagePermission('/admin/courses');
      allow update: if isAdmin() || hasPagePermission('/admin/courses') || (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeRegistrationCount'])
      );
    }

    match /sessions/{id} {
      allow read: if true;
      allow create, delete: if isAdmin() || hasPagePermission('/admin/courses');
      allow update: if isAdmin() || hasPagePermission('/admin/courses');
    }

    match /interruptions/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/interruptions');
    }

    match /publicHolidays/{id} {
      allow read: if true;
      allow write: if isAdmin() || hasPagePermission('/admin/public-holidays');
    }

    match /notifications/{id} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function uniquement
    }

    match /registrations/{id} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == request.resource.data.userId;
      allow update: if (isAuth() && resource.data.userId == request.auth.uid) || isAdmin() || hasPagePermission('/admin/courses');
      allow delete: if isAdmin() || hasPagePermission('/admin/courses');
    }

    // ── paiements ─────────────────────────────────────────────────────────────
    match /pricingPlans/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/pricing-plans');
    }

    match /memberships/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId) || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new');
      allow create: if isAdmin() || (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update: if isAdmin() || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new') || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentMethod', 'installmentIds', 'updatedAt']) &&
        resource.data.paymentPlanStatus == 'pending'
      );
      allow delete: if isAdmin() || hasPagePermission('/admin/payment-plans') || (
        isOwner(resource.data.userId) &&
        resource.data.paymentPlanStatus == 'pending' &&
        resource.data.installmentIds.size() == 0
      );
    }

    match /paymentGroups/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId) || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new');
      allow create: if isAdmin() || (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update: if isAdmin() || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new') || (
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['installmentIds', 'updatedAt']) &&
        resource.data.paymentPlanStatus == 'pending'
      );
      allow delete: if isAdmin() || hasPagePermission('/admin/payment-plans') || (
        isOwner(resource.data.userId) &&
        resource.data.paymentPlanStatus == 'pending' &&
        resource.data.installmentIds.size() == 0
      );
    }

    match /payments/{id} {
      allow read, write: if isAdmin() || hasPagePermission('/admin/payments/today');
    }

    match /paymentInstallments/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId) || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new');
      allow create: if isAdmin() || (isAuth() && request.auth.uid == request.resource.data.userId) || hasPagePermission('/admin/payments/new');
      allow update, delete: if isAdmin() || hasPagePermission('/admin/payment-plans') || hasPagePermission('/admin/payments/new');
    }

    match /chequeImages/{id} {
      allow read, write: if isAdmin() || hasPagePermission('/admin/payments/cheques');
    }

    match /bankDeposits/{id} {
      allow read, write: if isAdmin() || hasPagePermission('/admin/payments/bank-deposits');
    }

    match /bankAccounts/{id} {
      allow read, write: if isAdmin() || hasPagePermission('/admin/settings/bank-accounts');
    }

    match /attendances/{id} {
      allow read: if isAdmin() || isInstructor();
      allow create: if false; // Cloud Function uniquement
      allow update, delete: if isAdmin();
    }

    match /kioskSessions/{id} {
      allow read: if isAuth();
      allow create: if isAdmin() || isInstructor();
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin();
    }

    // ── media ─────────────────────────────────────────────────────────────────
    match /media/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/media');
    }

    // ── announcements (actualités home) ──────────────────────────────────────
    match /announcements/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/announcements');
    }

    // ── notificationChannels ──────────────────────────────────────────────────
    match /notificationChannels/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/notification-channels');
    }

    // ── chat ──────────────────────────────────────────────────────────────────
    match /chatChannels/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/chat-channels');
    }

    match /chatMessages/{id} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin() || hasPagePermission('/admin/chat-channels');
    }

    match /privateMessages/{id} {
      allow read: if isAdmin() || (isAuth() && resource.data.fromAccountId == request.auth.uid) || hasPagePermission('/admin/private-messages');
      allow create: if isAuth() && request.auth.uid == request.resource.data.fromAccountId;
      allow update: if isAdmin() || hasPagePermission('/admin/private-messages');
      allow delete: if isAdmin() || hasPagePermission('/admin/private-messages');
    }

    // ── documents personnels (reçus, attestations) ────────────────────────────
    match /documents/{id} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create, update, delete: if false; // Cloud Function uniquement
    }

    // ── bibliothèque de documents du club ─────────────────────────────────────
    match /documentLibrary/{id} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/documents-library');
    }

    match /documentLibrary/{docId}/versions/{versionId} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/documents-library');
    }

    // ── roles (configuration des rôles) ──────────────────────────────────────
    // Volontairement restreint au vrai rôle admin uniquement (jamais dynamique
    // via pagePermissions) pour éviter qu'un rôle puisse s'auto-accorder des droits.
    match /roles/{roleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── profileSchemas (champs personnalisés) ─────────────────────────────────
    match /profileSchemas/{schemaId} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/settings/custom-fields');
    }

    match /profileSchemas/{schemaId}/fields/{fieldId} {
      allow read: if isAuth();
      allow write: if isAdmin() || hasPagePermission('/admin/settings/custom-fields');
    }
  }
}
