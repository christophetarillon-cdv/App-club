# ── Environnement ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Firebase client (public) ─────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cdv-app-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cdv-app-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cdv-app-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (server-side uniquement — ne jamais exposer) ───────────────
FIREBASE_SERVICE_ACCOUNT_KEY=
