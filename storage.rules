rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.get(/databases/(default)/documents/accounts/$(request.auth.uid))
          .data.roles.hasAny(['admin']);
    }

    match /cheques/{imageId} {
      allow read, write: if isAdmin();
    }

    match /bank-deposits/{depositId} {
      allow read, write: if isAdmin();
    }

    match /profile-photos/{dancerId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
